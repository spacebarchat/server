{
    "extends": "../../tsconfig.base.json",
    "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
    "exclude": ["node_modules"],
    "compilerOptions": {
        "allowJs": true,
        "noEmit": true,
        "incremental": true,
        "jsx": "preserve",
        "module": "esnext",
        "moduleResolution": "bundler",
        "isolatedModules": true,
        "plugins": [{ "name": "next" }],
        "tsBuildInfoFile": ".next/cache/tsconfig.tsbuildinfo"
    }
}
